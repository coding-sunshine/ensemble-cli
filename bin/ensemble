#!/usr/bin/env php
<?php

if (isset($_composer_autoload_path)) {
    require $_composer_autoload_path;
} elseif (file_exists(__DIR__.'/../../../autoload.php')) {
    require __DIR__.'/../../../autoload.php';
} else {
    require __DIR__.'/../vendor/autoload.php';
}

$app = new Symfony\Component\Console\Application('Laravel Ensemble', '0.1.0');

$commands = [
    new CodingSunshine\Ensemble\Console\NewCommand,
    new CodingSunshine\Ensemble\Console\DraftCommand,
    new CodingSunshine\Ensemble\Console\InitCommand,
    new CodingSunshine\Ensemble\Console\ShowCommand,
    new CodingSunshine\Ensemble\Console\ValidateCommand,
    new CodingSunshine\Ensemble\Console\DiffCommand,
    new CodingSunshine\Ensemble\Console\ExportCommand,
    new CodingSunshine\Ensemble\Console\ConfigCommand,
    new CodingSunshine\Ensemble\Console\DoctorCommand,
    new CodingSunshine\Ensemble\Console\AiCommand,
    new CodingSunshine\Ensemble\Console\UpdateCommand,
];

foreach ($commands as $command) {
    if (method_exists($app, 'addCommand')) {
        $app->addCommand($command);
    } else {
        $app->add($command);
    }
}

$app->run();
